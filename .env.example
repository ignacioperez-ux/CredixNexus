# Supabase — copia este archivo a .env.local y completa con tus valores reales.
# Los encontras en: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-o-publishable-key

# SSO Entra ID (Azure) — FEATURE FLAG. Con "false" (o ausente) la app es identica a hoy:
# el boton "Ingresar con cuenta Credix" no se muestra y las rutas /auth/callback y /no-access
# son inertes. Se enciende SOLO el dia D, despues de configurar el proveedor Azure en el
# dashboard de Supabase. Ver docs/sso/RUNBOOK_ACTIVACION.md.
NEXT_PUBLIC_SSO_ENABLED=false

# IMPORTANTE — NINGUN secreto de SSO va aca ni al frontend. El tenant ID, client ID y client
# secret de Azure/Entra ID se configuran EXCLUSIVAMENTE en:
#   Supabase Dashboard > Authentication > Providers > Azure
# La app nunca los ve. Redirect URI a registrar en Azure (App Registration):
#   https://dffbysjrvvlwgzgakhaa.supabase.co/auth/v1/callback
